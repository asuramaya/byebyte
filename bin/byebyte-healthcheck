"""byebyte-healthcheck — are the daemon's vitals good?

Thin wrapper over sutra.check_health (UNIFY Wave A #3): status.json fresh
against the daemon's own declared poll_interval, control.sock answering
ping. Exit 0 when healthy, nonzero with a one-line reason when not.

Passive by design: it diagnoses and reports, it never restarts anything —
systemd's Restart= owns recovery, and a monitoring probe that mutates what
it measures can't be trusted. Honors BYEBYTE_RUNTIME_DIR exactly like
byebyted and byebyte do.
"""

import os
import sys

import sutra

RUNTIME_DIR = os.environ.get("BYEBYTE_RUNTIME_DIR", "/run/byebyte")
STATUS_PATH = os.path.join(RUNTIME_DIR, "status.json")
SOCKET_PATH = os.path.join(RUNTIME_DIR, "control.sock")


def main():
    healthy, reason, info = sutra.check_health(STATUS_PATH, SOCKET_PATH)
    if not healthy:
        print(f"byebyte-healthcheck: UNHEALTHY — {reason}")
        return 1
    print(f"byebyte-healthcheck: ok (status {info['age']:.0f}s old, "
          f"byebyted {info['version']} answering)")
    return 0


if __name__ == "__main__":
    sys.exit(main())

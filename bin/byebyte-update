"""byebyte-update — is a newer byebyte release out? Install it, on consent.

Thin wrapper over sutra_update (UNIFY Wave A #1, the family's update spine —
one grammar, one trust chain, one install-path detection, three consent
tiers). This is deliberately a SEPARATE program from the daemon: byebyted
never touches the network at all, so the one component that reaches the
internet is this small, unprivileged-when-checking updater — never the
privileged control loop (phanspeed's split, inherited verbatim).

  byebyte-update --check          human-readable: newer release or not
  byebyte-update --check --json   {"current","latest","available","armed"}
  byebyte-update                  manual install (explicit human consent)

auto_enabled is hardcoded False: byebyte-update.timer runs --check only
(family doctrine: updates are click-to-install) and no signing anchor
exists yet (Wave B's release-signing scaffold hasn't shipped) — an --auto
tier would no-op on the missing anchor regardless, but there's no config
knob pretending otherwise until that decision is made on purpose.
"""

import os
import sys

import sutra_update

_SRC_DIR = os.path.dirname(os.path.dirname(os.path.abspath(__file__)))
# .deb installs share/ under /usr; install.sh's source install defaults
# PREFIX to /usr/local — both are real, so both are checked before falling
# back to the repo-relative path for a dev checkout that's never been
# installed at all.
VERSION_CANDIDATES = ("/usr/share/byebyte/VERSION",
                      "/usr/local/share/byebyte/VERSION",
                      os.path.join(_SRC_DIR, "VERSION"))


def installed_version():
    for path in VERSION_CANDIDATES:
        try:
            with open(path) as f:
                v = f.read().strip()
            if v:
                return v
        except OSError:
            continue
    return "unknown"


if __name__ == "__main__":
    sys.exit(sutra_update.main(
        pill="byebyte", slug="asuramaya/ByeByte",
        installed_version=installed_version(),
        anchor_candidates=["/usr/share/byebyte/allowed_signers",
                           _SRC_DIR + "/release-signing/allowed_signers"],
        auto_enabled=False))

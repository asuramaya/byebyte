#!/usr/bin/env python3
"""byebyte — verb CLI over the byebyted control socket.

Talks to the daemon's socket; `status` falls back to reading status.json
so it still answers even mid-daemon-restart.
"""

import json
import os
import sys
import time

import sutra

RUNTIME_DIR = os.environ.get("BYEBYTE_RUNTIME_DIR", "/run/byebyte")

PLANNED = {}


def request(payload, timeout=30):
    """One JSON command to the daemon; None if the socket is unreachable."""
    sock_path = os.path.join(RUNTIME_DIR, "control.sock")
    return sutra.request(sock_path, payload, timeout=timeout)


def request_or_die(payload, timeout=30):
    doc = request(payload, timeout=timeout)
    if doc is None:
        sys.exit("byebyte: daemon unreachable — is byebyted running?")
    if isinstance(doc, dict) and "error" in doc:
        sys.exit(f"byebyte: {doc['error']}")
    return doc


def fetch():
    doc = request({"cmd": "status"})
    if isinstance(doc, dict) and "mounts" in doc:
        return doc
    doc = sutra.read_status(os.path.join(RUNTIME_DIR, "status.json"))
    if doc is None:
        sys.exit("byebyte: no daemon and no status.json — is byebyted running?")
    return doc


def human_bytes(n):
    for unit in ("B", "K", "M", "G", "T"):
        if abs(n) < 1024 or unit == "T":
            return f"{n:.0f}{unit}" if unit == "B" else f"{n / 1.0:.1f}{unit}"
        n /= 1024
    return f"{n:.1f}T"


def human_burn(bps):
    per_day = bps * 86400
    if abs(per_day) < 1024 * 1024:
        return "quiet"
    return f"{human_bytes(per_day)}/day"


def human_eta(seconds):
    if seconds is None:
        return "—"
    if seconds >= 14 * 86400:
        return f"~{seconds // (7 * 86400)}w"
    if seconds >= 2 * 86400:
        return f"~{seconds // 86400}d"
    if seconds >= 2 * 3600:
        return f"~{seconds // 3600}h"
    return f"~{max(1, seconds // 60)}m"


FLAGS = {"ok": " ", "warn": "!", "hot": "‼", "edquot": "✗"}


def cmd_status(argv):
    doc = fetch()
    if "--json" in argv:
        print(json.dumps(doc, indent=2))
        return
    age = int(time.time() - doc["ts"])
    print(f"byebyte v{doc['daemon']['version']}   (status {age}s old)")
    for m in doc["mounts"]:
        flag = FLAGS.get(m["state"], "?")
        line = (f" {flag} {m['mountpoint']:<12} "
                f"{human_bytes(m['effective_free']):>8} free "
                f"of {human_bytes(m['total']):>8}   "
                f"burn {human_burn(m['burn_bps']):<12} "
                f"full {human_eta(m['eta_seconds'])}")
        if m.get("quota"):
            q = m["quota"]
            line += (f"   [quota: {human_bytes(q['remaining'])}"
                     f" of {human_bytes(q['limit'])} left]")
        print(line)


def _flag_val(argv, name, default):
    if name in argv:
        i = argv.index(name)
        if i + 1 < len(argv):
            return argv[i + 1]
    return default


def _age_tag(newest_mtime, now):
    if not newest_mtime:
        return "?"
    days = (now - newest_mtime) / 86400
    if days < 1:
        return "hot"
    if days < 30:
        return f"{int(days)}d"
    if days < 90:
        return f"{int(days / 30)}mo"
    return f"cold {int(days / 30)}mo"


def parse_since(text, now):
    """'2h', '3d', '1w' or 'YYYY-MM-DD' -> epoch seconds."""
    units = {"h": 3600, "d": 86400, "w": 7 * 86400}
    if text and text[-1] in units:
        try:
            return now - float(text[:-1]) * units[text[-1]]
        except ValueError:
            pass
    try:
        return time.mktime(time.strptime(text, "%Y-%m-%d"))
    except ValueError:
        sys.exit(f"byebyte: bad --since '{text}' (want 2h / 3d / 1w"
                 " or YYYY-MM-DD)")


def cmd_scan(argv):
    doc = request_or_die({"cmd": "scan"})
    if doc.get("running") and not doc.get("started"):
        print("scan already running")
    else:
        print("scan started")
    if "--wait" in argv:
        while True:
            time.sleep(1)
            st = request_or_die({"cmd": "status"})
            idx = st.get("index") or {}
            if not idx.get("scanning"):
                age = int(time.time() - (idx.get("last_scan") or 0))
                print(f"scan done ({age}s ago)")
                return


def cmd_why(argv):
    path = next((a for a in argv if not a.startswith("-")
                 and a != _flag_val(argv, "--limit", None)), "/")
    limit = int(_flag_val(argv, "--limit", "15"))
    doc = request_or_die({"cmd": "why", "path": path, "limit": limit})
    if "--json" in argv:
        print(json.dumps(doc, indent=2))
        return
    now = time.time()
    age = human_eta(int(now - doc["scan_ts"])).lstrip("~")
    total = doc.get("total")
    head = f"{human_bytes(total)} in " if total is not None else ""
    print(f"{head}{doc['path']}   (scanned {age} ago)")
    for r in doc["rows"]:
        print(f"  {human_bytes(r['bytes']):>8}  {_age_tag(r['newest_mtime'], now):<10}"
              f"  {r['path']}")
    if not doc["rows"]:
        print("  (nothing above the index threshold here)")


def cmd_blame(argv):
    now = time.time()
    since = parse_since(_flag_val(argv, "--since", "1d"), now)
    limit = int(_flag_val(argv, "--limit", "15"))
    doc = request_or_die({"cmd": "blame", "since": since, "limit": limit})
    if "--json" in argv:
        print(json.dumps(doc, indent=2))
        return
    span = human_eta(int(doc["head_ts"] - doc["base_ts"])).lstrip("~")
    print(f"grew over the last {span} (parents include their children):")
    for r in doc["rows"]:
        sign = "+" if r["delta"] >= 0 else ""
        print(f"  {sign}{human_bytes(r['delta']):>8}  {r['path']}"
              f"  (now {human_bytes(r['bytes'])})")
    if not doc["rows"]:
        print("  nothing moved above the index threshold")


def cmd_purge(argv):
    positional = [a for a in argv if not a.startswith("-")]
    if not positional or positional[0] == "all" or "--all" in argv:
        sys.exit("byebyte purge: --all is refused — one category per act")
    category = positional[0]
    yes = "--yes" in argv
    doc = request_or_die({"cmd": "purge", "category": category, "dry_run": not yes})
    if "--json" in argv:
        print(json.dumps(doc, indent=2))
        return
    if doc.get("dry_run"):
        cands = doc.get("candidates", [])
        if not cands:
            print(f"{category}: nothing to purge")
            return
        for c in cands:
            print(f"  {human_bytes(c['bytes']):>8}  {c['path']}")
        print(f"{human_bytes(doc['total_bytes'])} would be freed"
              " (dry-run — add --yes to execute)")
    else:
        freed = doc.get("freed_bytes", 0)
        errors = [r for r in doc.get("results", []) if not r["ok"]]
        tail = f" ({len(errors)} failed)" if errors else ""
        print(f"{category}: freed {human_bytes(freed)}{tail}")


def cmd_ghosts(argv):
    doc = request_or_die({"cmd": "ghosts"})
    if "--json" in argv:
        print(json.dumps(doc, indent=2))
        return
    holders = doc.get("holders", [])
    if not holders:
        print("no ghosts — nothing deleted-but-open")
        return
    for h in holders:
        mounts = ",".join(h["mounts"]) if h["mounts"] else "?"
        print(f"  {human_bytes(h['bytes']):>8}  pid {h['pid']:<7} "
              f"{h['comm']:<16} {h['fds']} fd(s)  on {mounts}")
    print(f"{human_bytes(doc['total_bytes'])} held by deleted-but-open files")


def cmd_ballast(argv):
    action = "release" if (argv and argv[0] == "release") else "status"
    doc = request_or_die({"cmd": "ballast", "action": action})
    if "--json" in argv:
        print(json.dumps(doc, indent=2))
        return
    if action == "release":
        print(f"ballast released: {human_bytes(doc['freed_bytes'])} "
              f"({len(doc['released'])} slab(s))")
    else:
        slabs = doc.get("slabs", [])
        if not slabs:
            print("ballast: no slabs (off, or not built yet)")
            return
        for s in slabs:
            print(f"  {human_bytes(s['bytes']):>8}  {s['name']}")
        print(f"{human_bytes(doc['total_bytes'])} reserved")


def cmd_kernels(argv):
    doc = request_or_die({"cmd": "kernels"})
    if "--json" in argv:
        print(json.dumps(doc, indent=2))
        return
    print(f"running: {doc['running']}   newest: {doc['newest'] or '?'}")
    cands = doc.get("candidates", [])
    if not cands:
        print("no removal candidates")
        return
    for c in cands:
        pkg = c.get("package") or "(no dpkg package found)"
        print(f"  {c['version']:<24} {pkg}")
    if doc.get("apt_line"):
        print(doc["apt_line"])


def cmd_advise(argv):
    doc = request_or_die({"cmd": "advise"})
    if "--json" in argv:
        print(json.dumps(doc, indent=2))
        return
    findings = doc.get("findings", [])
    if not findings:
        print("advise: nothing to flag")
        return
    for f in findings:
        rule = f["rule"]
        if rule == "eta_soon":
            print(f"  {f['mount']} fills in {human_eta(int(f['eta_seconds']))}"
                  f" (burn {human_burn(f['burn_bps'])})")
        elif rule == "quota_low":
            pct = 100 * f["remaining"] / f["limit"] if f["limit"] else 0
            print(f"  {f['mount']} quota headroom low: "
                  f"{human_bytes(f['remaining'])} of {human_bytes(f['limit'])}"
                  f" left ({pct:.0f}%) — EDQUOT risk")
        elif rule == "fast_grower":
            print(f"  {f['path']} growing {human_bytes(f['bytes_per_day'])}/day")
        elif rule == "cold_cache":
            print(f"  {f['category']} is {human_bytes(f['bytes'])} and untouched"
                  f" 90+ days — cold cache")
        elif rule == "ghosts_heavy":
            print(f"  {human_bytes(f['bytes'])} held by deleted-but-open files"
                  f" — see: byebyte ghosts")
        else:
            print(f"  {rule}: {f}")


def cmd_burn(argv):
    seconds = int(_flag_val(argv, "--seconds", "5"))
    limit = int(_flag_val(argv, "--limit", "15"))
    doc = request_or_die({"cmd": "burn", "seconds": seconds, "limit": limit},
                          timeout=seconds + 10)
    if "--json" in argv:
        print(json.dumps(doc, indent=2))
        return
    writers = doc.get("writers", [])
    if not writers:
        print(f"no writes ≥ 1B/s over {doc.get('seconds', seconds)}s")
        return
    for w in writers:
        mount = f"  (writing on {w['mount']})" if w.get("mount") else ""
        print(f"  {human_bytes(w['bytes_per_sec']):>8}/s   pid {w['pid']:<7} "
              f"{w['comm']:<16}{mount}")


def main():
    argv = sys.argv[1:]
    verb = argv[0] if argv and not argv[0].startswith("-") else "status"
    rest = argv[1:] if argv and not argv[0].startswith("-") else argv
    verbs = {"status": cmd_status, "scan": cmd_scan,
             "why": cmd_why, "blame": cmd_blame, "purge": cmd_purge,
             "ghosts": cmd_ghosts, "ballast": cmd_ballast, "kernels": cmd_kernels,
             "advise": cmd_advise, "burn": cmd_burn}
    if verb in verbs:
        verbs[verb](rest)
    elif verb in PLANNED:
        sys.exit(f"byebyte {verb}: not yet — {PLANNED[verb]}")
    else:
        known = ", ".join(list(verbs) + list(PLANNED))
        sys.exit(f"byebyte: unknown verb '{verb}' (verbs: {known})")


if __name__ == "__main__":
    main()
